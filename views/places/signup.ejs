<% layout("/layouts/boilarplate") -%>

    <body>
        <div class=" row">
            <div class="col-6" offset-3>
                <h1>SignUp</h1>
                <form action="/signup" method="post" class="needs-validation" novalidate autocomplete="off">
                    <div class="mb-3 ">
                        <label for="username" class="form-label">Name</label>
                        <input type="text" name="username" class="form-control" id="username"
                            placeholder="Enter Name" minlength="1" maxlength="22"  required>
                        <div class="valid-feedback">
                            Title Looks good!
                        </div>
                    </div>
                
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" id="email"
                            placeholder="Enter Email Id"  maxlength="50" required>
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" name="password" class="form-control" id="password"
                            placeholder="Enter password" maxlength="10">
                    </div>
                    <button class="btn btn-dark">SignUp</button>
                </form>
            </div>
        </div>
    </body>