<% layout("/layouts/boilarplate") -%>

    <body>
          <form action="/places/<%= data.id %>/edit?_method=PUT" method="post" enctype="multipart/form-data">
        <h3>Edit Your Listing</h3>
        <div class="row">
            <div class="cal-8 ">
                <div class="mb-3 ">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" name="title" class="form-control" id="title" value="<%=data.title %>" required>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="description" class="form-control" id="description" required><%=data.description %></textarea>
                </div>
                <div class="mb-3">
                    <label for="image" class="form-label">Image File</label>
                  <input type="file" name="image" class="form-control" id="image">
                </div>
                <div class="mb-3">
                    <label class="form-label" for="price">Price</label>
                    <input type="number" name="price" class="form-control" id="price" value="<%=data.price %>" required>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="location">Location</label>
                    <input type="text" name="location" class="form-control" id="location" value="<%=data.location %>" required>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="country">Country</label>
                    <input type="text" name="country" class="form-control" id="country" value="<%=data.country %>" required>
                </div>
                <button type="submit" class="btn btn-dark btn-new-form">Submit</button>
                <br><br>
            </div>
        </div>
    </form>
    </body>
 