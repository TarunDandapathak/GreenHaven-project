<nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom sticky-top">
    <div class="container-fluid">

        <a class="navbar-brand" href="/places">
            <i class="fa-regular fa-compass"></i>
        </a>

        <!-- Toggle Button -->
        <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar">
            <span class="navbar-toggler-icon"></span>
            
        </button>

        <!-- Normal Navbar (Desktop) -->
        <div class="collapse navbar-collapse">

            <div class="navbar-nav ">
                <a class="nav-link" href="/places">Explore</a>
                <a class="nav-link" href="/places/new">New Post</a>
            </div>

            <form class="d-flex me-3" action="/places/search" method="post">
                <input class="form-control me-2 search" type="search" placeholder="Search Destination" name="search">
                <button class="btn btn-outline-success">
                    <i class="fa-solid fa-magnifying-glass"></i>Search
                </button>
            </form>

            <div class="navbar-nav">
                <% if (!currUser) { %>
                    <a class="nav-link" href="/signup">Sign Up</a>
                    <a class="nav-link" href="/login">Login</a>
                    <% } %>

                        <% if (currUser) { %>
                            <a class="nav-link hide" href="/profile">My Profile</a>
                            <a class="nav-link" href="/logout">Log Out</a>
                            <% } %>
            </div>

        </div>

        <!-- Offcanvas Menu (Mobile) -->
        <div class="offcanvas offcanvas-end" id="offcanvasNavbar">
            <div class="offcanvas-header">
                <h5>Menu</h5>
                <button class="btn-close" data-bs-dismiss="offcanvas"></button>
            </div>

            <div class="offcanvas-body">
                <div class="navbar-nav">
                    <a class="nav-link hide" href="/places">Explore</a>
                    <a class="nav-link hide" href="/places/new">New Post</a>

                    <% if (!currUser) { %>
                        <a class="nav-link hide " href="/signup">Sign Up</a>
                        <a class="nav-link hide" href="/login">Login</a>
                        <% } %>

                            <% if (currUser) { %>
                                <a class="nav-link hide" href="/profile">My Profile</a>
                                <a class="nav-link" href="/logout">Log Out</a>
                                <% } %>
                </div>
            </div>
        </div>

    </div>
</nav>
