<style>
    .btn-outline-success {
        background-color: #ff385c;
        color: white;
        border: none;
        border-radius: 10px;
    }

    .btn-outline-success:hover {
        background-color: #ff385c;
        color: white;
        border: none;
    }

    .btn-outline-success i {
        display: inline;
        padding-right: 2px;
    }

    @media (min-width:1000px) {
        .offcanvas-end {
            display: none;

        }

    }

    /* hide mobile search on desktop */
    .mobile-search {
        display: none;
    }

    /* hide desktop search on small screens */
    @media (max-width: 990px) {

        .navbar form {
            display: none;
        }

        .mobile-search {
            display: flex;
            justify-content: center;
            padding: 10px;
            background: white;
        }

        .mobile-search form {
            width: 90%;
        }
    }

    .search {
        width: 27rem;
    }
</style>
